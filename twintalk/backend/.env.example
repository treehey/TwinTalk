# Flask Server
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000

# Database
DATABASE_URL=sqlite:///digital_twin.db

# Tencent Hunyuan API (Required for Agent features)
# 获取你的 API 密钥: 腾讯云混元大模型控制台 -> API Key 管理
OPENAI_API_KEY=your-hunyuan-api-key-here
OPENAI_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
OPENAI_MODEL=hunyuan-lite
